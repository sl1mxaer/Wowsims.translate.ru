{
  "manifest_version": 3,
  "name": "Wowsims.translate.ru",
  "version": "1.0.9",
  "description": "Перевод тултипов Wowhead с английского на русский для wowsims.com",
  "icons": { "128": "icon.png" },
  "content_scripts": [
    {
      "matches": ["https://www.wowsims.com/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["https://www.wowsims.com/*"]
    }
  ],
  "permissions": ["activeTab"],
  "host_permissions": ["https://www.wowsims.com/*"]
}
