{
  "manifest_version": 3,
  "name": "Wowsims.translate.ru",
  "version": "1.0.7",
  "description": "Перевод тултипов Wowhead на русский (MOP Classic) для wowsims.com",
  "icons": {
    "128": "wowsims.png"
  },
  "content_scripts": [
    {
      "matches": ["https://www.wowsims.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "permissions": ["activeTab"],
  "host_permissions": ["https://www.wowsims.com/*"]
}
