{
  "manifest_version": 3,
  "name": "Wowsims.translate.ru",
  "version": "1.0.6",
  "description": "Перевод тултипов Wowhead на русский для wowsims.com",
  "content_scripts": [
    {
      "matches": ["https://www.wowsims.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "permissions": [
    "activeTab"
  ],
  "host_permissions": [
    "https://www.wowsims.com/*"
  ],
  "icons": {
    "16": "wowsims.png",
    "48": "wowsims.png",
    "128": "wowsims.png"
  }
}